# Upstash Kafka
UPSTASH_KAFKA_BOOTSTRAP=your-cluster.upstash.io:9092
UPSTASH_KAFKA_USERNAME=your-username
UPSTASH_KAFKA_PASSWORD=your-password

# Kafka Topics
KAFKA_TOPIC_REDDIT_RAW=reddit-raw
KAFKA_TOPIC_OL_READING_LOG=ol-reading-log
KAFKA_TOPIC_OL_RATINGS=ol-ratings
KAFKA_TOPIC_BOOKS_METADATA=books-metadata

# Google Cloud / BigQuery
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
BQ_DATASET=overdue

# Open Library Dump URLs
OL_READING_LOG_URL=https://openlibrary.org/data/ol_dump_reading-log_latest.txt.gz
OL_RATINGS_URL=https://openlibrary.org/data/ol_dump_ratings_latest.txt.gz

# Reddit Ingestion
REDDIT_SUBREDDITS=books,suggestmeabook,booksuggestions,literature,Fantasy,scifi,romancebooks,horrorlit,52book
REDDIT_START_YEAR=2018
REDDIT_END_YEAR=2023
