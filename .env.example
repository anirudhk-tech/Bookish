# Upstash Kafka
UPSTASH_KAFKA_BOOTSTRAP=your-cluster.upstash.io:9092
UPSTASH_KAFKA_USERNAME=your-username
UPSTASH_KAFKA_PASSWORD=your-password
KAFKA_TOPIC=cricket-balls

# Google Cloud / BigQuery
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
BQ_DATASET=cricket_pulse
BQ_TABLE=live_scores

# Producer
BALL_DELAY_SECONDS=2
