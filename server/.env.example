# Kafka (local Docker by default -- just run `docker compose up kafka`)
KAFKA_BOOTSTRAP=localhost:9092

# Uncomment these to use Upstash instead of local Kafka:
# KAFKA_BOOTSTRAP=your-cluster.upstash.io:9092
# UPSTASH_KAFKA_USERNAME=your-username
# UPSTASH_KAFKA_PASSWORD=your-password

# Kafka Topics
KAFKA_TOPIC_REDDIT_RAW=reddit-raw

# Google Cloud / BigQuery
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=overdue

# Reddit Ingestion
REDDIT_SUBREDDITS=books,suggestmeabook,booksuggestions,literature,Fantasy,scifi,romancebooks,horrorlit,52book
